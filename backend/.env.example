# Django
SECRET_KEY=change-me-to-a-long-random-string-at-least-50-chars
DEBUG=False

# Database (PostgreSQL)
DB_NAME=grc_db
DB_USER=grc_user
DB_PASSWORD=change-me-strong-password
DB_HOST=postgres
DB_PORT=5432

# Set to True only in local dev to skip the Celery worker (tasks run inline)
CELERY_TASK_ALWAYS_EAGER=False

# Redis (broker + cache + channel layer)
REDIS_URL=redis://redis:6379/1
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Frontend URL (used for CORS + email links)
FRONTEND_BASE_URL=http://localhost

# Extra allowed hosts (comma-separated, add your domain in production)
EXTRA_ALLOWED_HOSTS=

# Email — set EMAIL_PROVIDER to: console (dev/test), gmail, or sendgrid
EMAIL_PROVIDER=console
DEFAULT_FROM_EMAIL=noreply@example.com

# Gmail SMTP (if EMAIL_PROVIDER=gmail)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True

# SendGrid (if EMAIL_PROVIDER=sendgrid)
SENDGRID_API_KEY=

# Sentry (optional error tracking)
SENTRY_DSN=
